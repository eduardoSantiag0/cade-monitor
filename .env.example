# ============================================================
# CADE Monitor / Meskade - Exemplo de configuração
# Copie este arquivo para .env e preencha com valores reais.
#
# IMPORTANTE:
# - Nunca commite o arquivo .env com senhas, tokens ou chaves reais.
# - O .env.example deve conter apenas exemplos e placeholders.
# ============================================================


# ============================================================
# Banco local
# ============================================================

DB_PATH=data/cade-monitor.sqlite3
SQLITE_PATH=data/cade-monitor.sqlite3


# ============================================================
# Login do painel web
# Troque antes de publicar em produção.
# ============================================================

ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha

# Use uma chave longa, aleatória e secreta.
APP_SECRET_KEY=troque-esta-chave-com-32-caracteres-ou-mais
SECRET_KEY=troque-esta-chave-com-32-caracteres-ou-mais


# ============================================================
# Configuração geral da aplicação
# ============================================================

DEBUG=false

# Hosts permitidos separados por vírgula.
# Em produção, prefira usar seu domínio real.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

APP_TIMEZONE=America/Sao_Paulo

# URL pública da aplicação, se houver.
# Exemplo: https://monitor.seudominio.com.br
BASE_URL=https://seu-dominio.example

# Endereço e porta do servidor web.
# Em produção com Docker/reverse proxy, normalmente HOST=0.0.0.0.
HOST=0.0.0.0
PORT=18087


# ============================================================
# Monitoramento
# Para muitas URLs/processos, use intervalos maiores para não
# sobrecarregar o site público.
# ============================================================

POLL_INTERVAL_SECONDS=30
CHECK_INTERVAL_SECONDS=30
WORKER_TICK_SECONDS=5
REQUEST_TIMEOUT_SECONDS=20

# Identifique sua aplicação e um contato real.
USER_AGENT=CADEMonitor/0.1 contato: seu-email@dominio.com.br

MAX_PROCESSES_PER_CYCLE=20
SLEEP_BETWEEN_REQUESTS_SECONDS=2
MAX_SNAPSHOTS_PER_PROCESS=100
MAX_NOTIFICATION_ATTEMPTS=3


# ============================================================
# E-mail via SMTP
# Para Gmail, use senha de app, não a senha normal da conta.
# ============================================================

SMTP_ENABLED=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASSWORD=senha-ou-app-password

# Pode ser só o e-mail ou no formato:
# MAIL_FROM=Nome do Sistema <usuario@example.com>
MAIL_FROM=usuario@example.com

SMTP_TLS=true
SMTP_SSL=false


# ============================================================
# WhatsApp via Evolution API
# Provider único: Evolution API
# ============================================================

EVOLUTION_ENABLED=false

# Se a aplicação e a Evolution API estiverem no mesmo docker-compose,
# talvez seja melhor usar o nome do serviço Docker em vez de localhost.
# Exemplo:
# EVOLUTION_API_BASE_URL=http://evolution-api:8080
EVOLUTION_API_BASE_URL=http://localhost:8080

EVOLUTION_API_KEY=troque-pela-api-key-da-evolution

# Nome da instância criada na Evolution API.
EVOLUTION_INSTANCE_NAME=cade-monitor

# Se seu código usar uma chave/ID específica da instância, preencha aqui.
# Caso não use, deixe vazio.
EVOLUTION_INSTANCE_KEY=

EVOLUTION_TIMEOUT_SECONDS=15

# Versao da sessao do WhatsApp Web usada pela Evolution/Baileys.
# Se nao estiver definida, o QR pode ficar travado em estado "connecting".
CONFIG_SESSION_VERSION=2.3000.1015901307

# WebSocket / QR Code
WEBSOCKET_ENABLED=true
WEBSOCKET_GLOBAL_EVENTS=true
QRCODE_LIMIT=60
QRCODE_COLOR=000000

# Evento de QR no RabbitMQ (opcional)
RABBITMQ_EVENTS_QRCODE_UPDATED=false


# ============================================================
# Logs
# Opções comuns: DEBUG, INFO, WARNING, ERROR
# ============================================================

LOG_LEVEL=INFO